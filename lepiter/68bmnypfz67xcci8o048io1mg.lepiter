								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2023-11-24T13:24:42.411716-05:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "Z1MIazi7DQC84LmsB5xAaQ=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "CSV - Missing a few things, like FITID, lumps name and memo together; seemingly functionally equivalent to QIF, with the benefit of easy parsing."
						}
