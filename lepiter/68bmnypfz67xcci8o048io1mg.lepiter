				"uid" : {
					"__type" : "uid",
					"uidString" : "Emv7xQ9hR7WIlTksJBQGgg=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "#Name parsing"
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-16T14:02:22.664323-04:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-16T14:09:09.223901-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "2iEhJZy3SUmvTnIKx8O2FA=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "Transaction \"names\" seem to be variations of the vendor name with additional info on either side (before or after), which may or may not be separated by # or *. As an initial strategy, we will copy everything that's not part of the counterparty's name into the memo. What constitutes \"part of the name\" will be up to the user, who can include various aliases for the contact or not. For example, if the user wants to consider \"Target.com\" to be the same as Target, and makes the former is an alias, none of that info will end up in the memo; but if there is no alias, \"Target\" will be the party, and \".com\" will be added to the memo reminding the user that this was an online order.\n\nThe fact that separators are optional from our perspective adds a wrinkle to parsing because we must consider \"name details\" e.g. Target.com * extra-info would be: [name][name details ie \".com\"] asterisk extra-info"
			}
		]
	},
