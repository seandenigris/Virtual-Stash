								"uidString" : "UFV6cji7DQCAXYGMB5xAaQ=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "QIF - older than OFX; \"The inability to reconcile imported transactions against the current account information is one of the primary shortcomings\" ([per Wikipedia](https://en.wikipedia.org/wiki/Quicken_Interchange_Format))"
						},
