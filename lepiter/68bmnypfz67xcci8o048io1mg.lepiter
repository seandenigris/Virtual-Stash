							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "OFX (and variants below) - seems to have the most information, like Transaction ID, which helps to match up previously imported transactions to new ones."
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [ ]
							},
