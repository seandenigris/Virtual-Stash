							"uid" : {
								"__type" : "uid",
								"uidString" : "hHNFSB8TTxOdt8UbgaRVdw=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "{{olObject:uid=beicoj8denmg14nysjl66kcpf}} - \"probably the cleanest commercial example... [but] more than you need for home books\" - [ChatGPT](https://chatgpt.com/c/6a4fc501-0068-83ea-a783-4c6b0a330f8b)"
						},
						{
							"__type" : "textSnippet",
							"children" : {
