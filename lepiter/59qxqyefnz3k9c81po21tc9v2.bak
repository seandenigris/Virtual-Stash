											}
										},
										"uid" : {
											"__type" : "uid",
											"uidString" : "ZoJ+XZCjTGCwDJegJiYEIQ=="
										},
										"paragraphStyle" : {
											"__type" : "textStyle"
										},
										"string" : "Distinctions of interest:\nAs booked\n    What context and allocation were asserted when the posting was finalized?\n\nAs of date\n    What did the object graph say at the reporting date?\n\nAs currently understood\n    Reinterpret historical postings through the current graph."
									}
								]
							},
							"createEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"createTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-07-22T11:59:35.506531-04:00"
								}
							},
							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-07-22T11:59:35.506531-04:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "LT+mYMLrRAeQ814m/XzmvQ=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "Fixing history. Inherited facts must be temporal, overrideable, and auditable. As Dynabook objects, like projects, evolve over time, say by adding participants, previous transaction data should remain unchanged. For example, I am doing martial arts, so that project, and its transactions would show up in a report on my expenses. If my wife later begins to practice, later reports should show these expenses on both of our reports, but reports prior to that time should not show up on hers."
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [
									{
										"__type" : "textSnippet",
										"children" : {
											"__type" : "snippets",
											"items" : [ ]
										},
										"createEmail" : {
											"__type" : "email",
											"emailString" : "<unknown>"
										},
										"createTime" : {
											"__type" : "time",
											"time" : {
												"__type" : "dateAndTime",
												"dateAndTimeString" : "2026-07-22T11:58:31.226628-04:00"
											}
										},
										"editEmail" : {
											"__type" : "email",
											"emailString" : "<unknown>"
										},
										"editTime" : {
											"__type" : "time",
											"time" : {
												"__type" : "dateAndTime",
												"dateAndTimeString" : "2026-07-22T11:58:59.108428-04:00"
											}
										},
										"uid" : {
											"__type" : "uid",
											"uidString" : "pVNVWB7ARVK8c4eGysqPWQ=="
										},
										"paragraphStyle" : {
											"__type" : "textStyle"
										},
										"string" : "Reports can specify an allocation policy:\nFullAttribution\n    The whole transaction is related to every listed value.\n    Totals overlap and are non-additive.\n\nUnion\n    Count each posting once when asking for the combined total.\n\nExplicitAllocation\n    Personal 90%\n    Business 10%\n    Weights total 100%.\n\nEqualAllocation\n    Divide evenly, but only when the user deliberately selects this policy.\n\nExclusiveClassification\n    Exactly one value receives the amount."
									}
								]
							},
							"createEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
