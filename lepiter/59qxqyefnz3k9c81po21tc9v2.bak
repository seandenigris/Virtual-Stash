	"pageType" : {
		"__type" : "namedPage",
		"title" : "Analytical Dimensions (AKA Tags)"
	},
	"children" : {
		"__type" : "snippets",
		"items" : [
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
