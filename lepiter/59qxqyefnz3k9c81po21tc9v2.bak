									"dateAndTimeString" : "2026-07-22T11:36:52.11264-04:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "UeBPtXs1QfKTQiQVQMHXMA=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "Aggregation: summing categories with multiple parents might double-count some transactions"
						}
					]
