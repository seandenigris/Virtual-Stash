							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "The contract dimension might find active subscriptions, memberships, licenses, insurance arrangements, and renewal obligations. Subscription modelling should retain its subscription behavior:\nrenewalDate\ncancellationTerms\npriceHistory\nincludedEntitlements\npaymentMethod"
						}
					]
				},
