										"uid" : {
											"__type" : "uid",
											"uidString" : "y++vJxOYTt+6Zqc+M6oJQg=="
										},
										"paragraphStyle" : {
											"__type" : "textStyle"
										},
										"string" : "Possible solutions:\n- Versioned objects: Relationships have effective dates.\n- Snapshot-at-posting: The transaction retains the inherited facts as they existed when posted.\n- Bitemporal data: Track both when a fact applied in reality and when the system learned or changed it.\n- Provenance-aware inference: The report can show whether a classification was explicit, inherited, inferred, or later overridden."
									},
									{
										"__type" : "textSnippet",
										"children" : {
											"__type" : "snippets",
											"items" : [ ]
										},
										"createEmail" : {
											"__type" : "email",
											"emailString" : "<unknown>"
										},
										"createTime" : {
											"__type" : "time",
											"time" : {
												"__type" : "dateAndTime",
												"dateAndTimeString" : "2026-07-22T11:59:40.752147-04:00"
											}
										},
										"editEmail" : {
											"__type" : "email",
											"emailString" : "<unknown>"
										},
										"editTime" : {
											"__type" : "time",
											"time" : {
